# ── Sentinel AI GRC Auditor — Environment Configuration ──────────────────────
# Minimum to run with mock data (no real credentials needed):
#   ENVIRONMENT=development   STORAGE_BACKEND=local
# Copy to .env and fill in what you have.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development           # development | production

# Google Gemini (hallucination scoring — optional, falls back to local scorer)
GOOGLE_API_KEY=your-gemini-api-key-here

# Storage
STORAGE_BACKEND=local             # local | gcs
GCS_BUCKET_NAME=sentinel-reports  # Only used when STORAGE_BACKEND=gcs
# LOCAL_STORAGE_PATH=             # Optional override — defaults to OS temp dir
#   Windows default: C:\Users\<you>\AppData\Local\Temp\sentinel-reports
#   macOS/Linux default: /tmp/sentinel-reports

# Arize AI (trace data — Arize MCP — leave empty to use mock data)
ARIZE_API_KEY=
ARIZE_SPACE_KEY=

# Elastic (log scanning — Elastic MCP — leave empty to use mock data)
ELASTIC_API_KEY=
ELASTIC_CLOUD_ID=

# Mock target agent URL (used in UI default)
MOCK_AGENT_URL=http://localhost:8001/chat

# CORS allowed origins
CORS_ORIGINS=http://localhost:3000

# Google Cloud (production only)
GOOGLE_CLOUD_PROJECT=
CLOUD_RUN_REGION=europe-west1
